{
  "uid": "platform-messaging",
  "title": "Platform Messaging",
  "tags": ["platform", "messaging"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(messaging_outbox_backlog, service)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Outbox age (oldest unpublished)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "messaging_outbox_age_seconds{service=~\"$service\"}", "legendFormat": "{{service}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Outbox backlog (unpublished rows)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "messaging_outbox_backlog{service=~\"$service\"}", "legendFormat": "{{service}}" }
      ]
    },
    {
      "type": "stat",
      "title": "DLQ count",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [
        { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
      "targets": [
        { "expr": "sum by (service) (messaging_dlq_count{service=~\"$service\"})", "legendFormat": "{{service}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Publish failures /s",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 8 },
      "targets": [
        { "expr": "rate(messaging_publish_failures_total{service=~\"$service\"}[5m])", "legendFormat": "{{service}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Consumer retries /s",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 8 },
      "targets": [
        { "expr": "rate(messaging_consumer_retries_total{service=~\"$service\"}[5m])", "legendFormat": "{{service}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Projection lag",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "messaging_projection_lag_seconds{service=~\"$service\"}", "legendFormat": "{{service}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Consumer processing latency (avg)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "rate(messaging_consumer_latency_seconds_sum{service=~\"$service\"}[5m]) / rate(messaging_consumer_latency_seconds_count{service=~\"$service\"}[5m])", "legendFormat": "{{service}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "RabbitMQ queue depth (ready)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        { "expr": "rabbitmq_queue_messages_ready", "legendFormat": "{{queue}}" }
      ]
    }
  ]
}
