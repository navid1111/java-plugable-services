{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/event-envelope-v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["eventId","eventType","eventVersion","occurredAt","producer","aggregateType","aggregateId","aggregateVersion","correlationId","payload"],
  "properties": {
    "eventId": {"type":"string","format":"uuid"},
    "eventType": {"type":"string","minLength":1},
    "eventVersion": {"type":"integer","minimum":1},
    "occurredAt": {"type":"string","format":"date-time"},
    "producer": {"type":"string","minLength":1},
    "aggregateType": {"type":"string","minLength":1},
    "aggregateId": {"type":"string","minLength":1},
    "aggregateVersion": {"type":"integer","minimum":1},
    "correlationId": {"type":"string","format":"uuid"},
    "causationId": {"type":["string","null"],"format":"uuid"},
    "traceparent": {"type":["string","null"]},
    "payload": {"type":"object"}
  }
}
