# Copy this file to .env before running Docker Compose or smoke tests.
# Never commit the real .env file.

# Auth/Kong JWT settings
JWT_SECRET=change-me-super-secret-jwt-signing-key-min-32-bytes-0123456789
JWT_ISSUER=springboot-auth

# Cloudinary credentials for media-service.
# Fill these from the Cloudinary dashboard before testing media upload.
CLOUDINARY_CLOUD_NAME=your--name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Media-service provider/runtime settings
CLOUDINARY_UPLOAD_FOLDER=pluggable-services-dev
MEDIA_MAX_IMAGE_BYTES=10485760
MEDIA_MAX_VIDEO_BYTES=104857600
MEDIA_ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,gif,webp
MEDIA_ALLOWED_VIDEO_FORMATS=mp4,mov,webm

# Planned media-service database settings
MEDIA_DB_NAME=mediadb
MEDIA_DB_USERNAME=mediauser
MEDIA_DB_PASSWORD=mediapass
